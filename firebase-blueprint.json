{
  "entities": {
    "Song": {
      "title": "Song",
      "description": "A generated song with its metadata and audio data.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "userId": { "type": "string" },
        "prompt": { "type": "string" },
        "title": { "type": "string" },
        "genre": { "type": "string" },
        "mood": { "type": "string" },
        "key": { "type": "string" },
        "scale": { "type": "string" },
        "instruments": { "type": "array", "items": { "type": "string" } },
        "duration": { "type": "number" },
        "audioUrl": { "type": "string" },
        "lyrics": { "type": "string" },
        "coverArtUrl": { "type": "string" },
        "shareId": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["userId", "prompt", "audioUrl", "shareId", "createdAt"]
    },
    "User": {
      "title": "User",
      "description": "User profile information.",
      "type": "object",
      "properties": {
        "uid": { "type": "string" },
        "email": { "type": "string" },
        "displayName": { "type": "string" },
        "photoURL": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["uid", "email"]
    }
  },
  "firestore": {
    "/songs/{songId}": {
      "schema": "Song",
      "description": "Collection of all generated songs."
    },
    "/users/{userId}": {
      "schema": "User",
      "description": "User profile documents."
    }
  }
}
